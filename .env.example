# SlugFound environment variables — copy to .env.local and fill in real values.
# .env.local is gitignored; never commit real secrets.

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER ONLY, bypasses RLS. Used by the email notification
# and unsubscribe routes (US 4.4). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI features ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-key   # photo search + embeddings (app/lib/gemini.ts)
GROQ_API_KEY=your-groq-key       # AI item scan (app/api/ai/scan-item)

# ── Email notifications (US 4.4) ────────────────────────────────────────────
RESEND_API_KEY=your-resend-key
EMAIL_FROM=SlugFound <onboarding@resend.dev>
# Shared secret sent by the Supabase webhook and verified by the route.
NOTIFY_WEBHOOK_SECRET=generate-a-long-random-string
# Public base URL of the deployed app — used in email links and as the webhook
# target. Cloud Supabase cannot reach localhost, so this must be a public URL.
NEXT_PUBLIC_APP_URL=https://your-app.example.com
